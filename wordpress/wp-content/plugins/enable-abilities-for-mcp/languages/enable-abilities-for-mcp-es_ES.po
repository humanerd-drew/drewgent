#. Plugin Name of the plugin
msgid "Enable Abilities for MCP"
msgstr "Enable Abilities for MCP"

#. Description of the plugin
msgid "Manage which WordPress Abilities are exposed to MCP servers. Enable or disable each ability individually from the dashboard."
msgstr "Gestiona qué capacidades de WordPress se exponen a los servidores MCP. Activa o desactiva cada capacidad individualmente desde el escritorio."

#. Author of the plugin
msgid "Fabio Montenegro"
msgstr "Fabio Montenegro"

#. Author URI of the plugin
msgid "https://fabiomontenegro.com"
msgstr "https://fabiomontenegro.com"

msgid "WordPress Core"
msgstr "WordPress Core"

msgid "Native WordPress core abilities. Exposed to MCP with the public flag."
msgstr "Capacidades nativas del núcleo de WordPress. Se exponen a MCP con la marca pública."

msgid "Site Information"
msgstr "Información del sitio"

msgid "General site data: name, URL, description, language, timezone, WP version."
msgstr "Datos generales del sitio: nombre, URL, descripción, idioma, zona horaria y versión de WP."

msgid "User Information"
msgstr "Información del usuario"

msgid "Current user data: name, email, role, avatar."
msgstr "Datos del usuario actual: nombre, correo electrónico, rol y avatar."

msgid "Environment Information"
msgstr "Información del entorno"

msgid "Technical details: PHP version, DB server, environment type."
msgstr "Detalles técnicos: versión de PHP, servidor de base de datos y tipo de entorno."

msgid "Read (Query Only)"
msgstr "Lectura (solo consulta)"

msgid "Only query data, do not modify anything. Safest to expose via MCP."
msgstr "Solo consulta datos, no modifica nada. La opción más segura para exponer a través de MCP."

msgid "Get Posts"
msgstr "Obtener entradas"

msgid "List posts with filters by status, category, count, and order."
msgstr "Lista entradas con filtros por estado, categoría, cantidad y orden."

msgid "Get Single Post"
msgstr "Obtener una entrada"

msgid "Full post detail by ID, including content, meta data, and featured image."
msgstr "Detalle completo de una entrada por ID, incluyendo contenido, metadatos e imagen destacada."

msgid "Get Categories"
msgstr "Obtener categorías"

msgid "List all categories with ID, name, slug, and post count."
msgstr "Lista todas las categorías con ID, nombre, slug y recuento de entradas."

msgid "Get Tags"
msgstr "Obtener etiquetas"

msgid "List all tags with ID, name, slug, and post count."
msgstr "Lista todas las etiquetas con ID, nombre, slug y recuento de entradas."

msgid "Get Pages"
msgstr "Obtener páginas"

msgid "List site pages with title, status, and hierarchy."
msgstr "Lista las páginas del sitio con título, estado y jerarquía."

msgid "Get Single Page"
msgstr "Obtener una página"

msgid "Full page detail by ID, including content, template, hierarchy, and SEO metadata."
msgstr "Detalle completo de una página por ID, incluyendo contenido, plantilla, jerarquía y metadatos SEO."

msgid "Get Comments"
msgstr "Obtener comentarios"

msgid "List comments with filters by status, post, and count."
msgstr "Lista comentarios con filtros por estado, entrada y cantidad."

msgid "Get Media"
msgstr "Obtener medios"

msgid "List media library files with filters by type."
msgstr "Lista los archivos de la biblioteca de medios con filtros por tipo."

msgid "Get Users"
msgstr "Obtener usuarios"

msgid "List site users with ID, name, email, and role."
msgstr "Lista los usuarios del sitio con ID, nombre, correo electrónico y rol."

msgid "Write (Create & Modify)"
msgstr "Escritura (crear y modificar)"

msgid "Create or modify content. Require appropriate MCP user permissions."
msgstr "Crea o modifica contenido. Requiere los permisos de usuario MCP adecuados."

msgid "Create Post"
msgstr "Crear entrada"

msgid "Create a new post with title, content, categories, tags, featured image, and more."
msgstr "Crea una nueva entrada con título, contenido, categorías, etiquetas, imagen destacada y más."

msgid "Update Post"
msgstr "Actualizar entrada"

msgid "Modify an existing post. Only updates the fields provided."
msgstr "Modifica una entrada existente. Solo actualiza los campos proporcionados."

msgid "Delete Post"
msgstr "Eliminar entrada"

msgid "Send a post to trash or permanently delete it."
msgstr "Envía una entrada a la papelera o la elimina de forma permanente."

msgid "Create Category"
msgstr "Crear categoría"

msgid "Create a new category with name, slug, description, and parent."
msgstr "Crea una nueva categoría con nombre, slug, descripción y categoría padre."

msgid "Create Tag"
msgstr "Crear etiqueta"

msgid "Create a new tag with name, slug, and description."
msgstr "Crea una nueva etiqueta con nombre, slug y descripción."

msgid "Create Page"
msgstr "Crear página"

msgid "Create a new page with title, content, status, and parent page."
msgstr "Crea una nueva página con título, contenido, estado y página padre."

msgid "Moderate Comment"
msgstr "Moderar comentario"

msgid "Change comment status: approve, hold, spam, or trash."
msgstr "Cambia el estado de un comentario: aprobar, retener, spam o papelera."

msgid "Reply to Comment"
msgstr "Responder a comentario"

msgid "Reply to an existing comment as the authenticated user."
msgstr "Responde a un comentario existente como el usuario autenticado."

msgid "Update Comment"
msgstr "Actualizar comentario"

msgid "Update content, author name, email, or WordPress user of an existing comment."
msgstr "Actualiza el contenido, nombre del autor, correo electrónico o usuario de WordPress de un comentario existente."

msgid "Upload Image from URL"
msgstr "Subir imagen desde URL"

msgid "Download an image from an external URL and register it in the media library. Returns the attachment ID."
msgstr "Descarga una imagen de una URL externa y la registra en la biblioteca de medios. Devuelve el ID del adjunto."

msgid "SEO — Rank Math"
msgstr "SEO — Rank Math"

msgid "Query and update Rank Math SEO metadata on posts and pages."
msgstr "Consulta y actualiza los metadatos SEO de Rank Math en entradas y páginas."

msgid "Get Rank Math Metadata"
msgstr "Obtener metadatos de Rank Math"

msgid "Get Rank Math SEO metadata for a post or page: title, description, keywords, robots, Open Graph, and more."
msgstr "Obtiene los metadatos SEO de Rank Math para una entrada o página: título, descripción, palabras clave, robots, Open Graph y más."

msgid "Update Rank Math SEO / Focus Keyword"
msgstr "Actualizar SEO de Rank Math / Palabra clave principal"

msgid "Update focus keyword, SEO title, description, canonical URL, robots, and Open Graph via Rank Math."
msgstr "Actualiza la palabra clave principal, el título SEO, la descripción, la URL canónica, los robots y Open Graph a través de Rank Math."

msgid "Update Rank Math Schema"
msgstr "Actualizar esquema de Rank Math"

msgid "Write a structured-data schema block (FAQPage, Article, Product, etc.) to a Rank Math schema meta key as a PHP-serialized array, so it renders as JSON-LD in <head>."
msgstr "Escribe un bloque de datos estructurados (FAQPage, Article, Product, etc.) en la clave meta de esquema de Rank Math como un array serializado en PHP, de modo que se muestre como JSON-LD en el <head>."

msgid "SEO — SEOPress"
msgstr "SEO — SEOPress"

msgid "Query and update SEOPress metadata on posts and pages."
msgstr "Consulta y actualiza los metadatos de SEOPress en entradas y páginas."

msgid "Get SEOPress Metadata"
msgstr "Obtener metadatos de SEOPress"

msgid "Get SEOPress metadata for a post or page: title, description, focus keyword, robots, canonical, Open Graph, and Twitter Card."
msgstr "Obtiene los metadatos de SEOPress para una entrada o página: título, descripción, palabra clave principal, robots, URL canónica, Open Graph y Twitter Card."

msgid "Update SEOPress Metadata"
msgstr "Actualizar metadatos de SEOPress"

msgid "Update SEOPress SEO title, description, focus keyword, canonical URL, robots directives, and Open Graph / Twitter Card fields."
msgstr "Actualiza el título SEO, la descripción, la palabra clave principal, la URL canónica, las directivas de robots y los campos de Open Graph/Twitter Card de SEOPress."

msgid "SEO — Yoast SEO"
msgstr "SEO — Yoast SEO"

msgid "Query and update Yoast SEO metadata on posts and pages."
msgstr "Consulta y actualiza los metadatos de Yoast SEO en entradas y páginas."

msgid "Get Yoast SEO Metadata"
msgstr "Obtener metadatos de Yoast SEO"

msgid "Get Yoast SEO metadata for a post or page: title, description, focus keyphrase, canonical, robots, Open Graph, and Twitter Card."
msgstr "Obtiene los metadatos de Yoast SEO para una entrada o página: título, descripción, frase clave principal, URL canónica, robots, Open Graph y Twitter Card."

msgid "Update Yoast SEO Metadata"
msgstr "Actualizar metadatos de Yoast SEO"

msgid "Update Yoast SEO title, description, focus keyphrase, canonical URL, robots, and Open Graph / Twitter Card fields."
msgstr "Actualiza el título SEO, la descripción, la frase clave principal, la URL canónica, los robots y los campos de Open Graph/Twitter Card de Yoast SEO."

msgid "Get Yoast Sitemap Index"
msgstr "Obtener índice del mapa del sitio de Yoast"

msgid "Fetch and parse the Yoast SEO sitemap index, returning the list of all sitemap URLs registered on the site."
msgstr "Obtiene y analiza el índice del mapa del sitio de Yoast SEO, devolviendo la lista de todas las URLs de los mapas del sitio registrados."

msgid "Utility"
msgstr "Utilidades"

msgid "Auxiliary tools that complement the workflow."
msgstr "Herramientas auxiliares que complementan el flujo de trabajo."

msgid "Search and Replace"
msgstr "Buscar y reemplazar"

msgid "Search for text in a post content and replace it with another."
msgstr "Busca texto en el contenido de una entrada y lo reemplaza por otro."

msgid "Site Statistics"
msgstr "Estadísticas del sitio"

msgid "Site summary: total posts, pages, categories, tags, comments, and users."
msgstr "Resumen del sitio: total de entradas, páginas, categorías, etiquetas, comentarios y usuarios."

msgid "Update Post Meta"
msgstr "Actualizar metadato de entrada"

msgid "Write any post meta field by exact key. Requires edit_post capability on the target post."
msgstr "Escribe cualquier campo de metadato de una entrada por clave exacta. Requiere la capacidad edit_post en la entrada de destino."

msgid "Get Post Meta"
msgstr "Obtener metadato de entrada"

msgid "Read any single post meta field by exact key. Returns the value and whether the key exists."
msgstr "Lee cualquier campo de metadato de una entrada por clave exacta. Devuelve el valor e indica si la clave existe."

msgid "Get Active Plugins"
msgstr "Obtener plugins activos"

msgid "Returns all active plugins with name, version, and detected capabilities (SEO, multilanguage, WooCommerce, etc.)."
msgstr "Devuelve todos los plugins activos con nombre, versión y capacidades detectadas (SEO, multiidioma, WooCommerce, etc.)."

msgid "Code Snippets"
msgstr "Fragmentos de código"

msgid "Create PHP code snippets via the Code Snippets plugin. Requires manage_options. Snippets are always created as inactive — they must be activated manually from wp-admin › Snippets."
msgstr "Crea fragmentos de código PHP a través del plugin Code Snippets. Requiere manage_options. Los fragmentos siempre se crean como inactivos y deben activarse manualmente desde wp-admin › Fragmentos."

msgid "Create Code Snippet"
msgstr "Crear fragmento de código"

msgid "Creates a PHP snippet (always inactive). Validates syntax, blocks dangerous functions (eval, exec, shell_exec, etc.), and fires an audit action hook."
msgstr "Crea un fragmento PHP (siempre inactivo). Valida la sintaxis, bloquea funciones peligrosas (eval, exec, shell_exec, etc.) y activa un hook de auditoría."

msgid "Multilanguage"
msgstr "Multiidioma"

msgid "Assign languages and link translation groups between posts via Polylang or WPML."
msgstr "Asigna idiomas y vincula grupos de traducción entre entradas mediante Polylang o WPML."

msgid "Set Post Language"
msgstr "Establecer idioma de la entrada"

msgid "Assign a language code to an existing post via Polylang or WPML."
msgstr "Asigna un código de idioma a una entrada existente mediante Polylang o WPML."

msgid "Link Post Translation"
msgstr "Vincular traducción de entrada"

msgid "Link two posts as translations of each other in the same translation group."
msgstr "Vincula dos entradas como traducciones una de la otra dentro del mismo grupo de traducción."

msgid "Get Post Translations"
msgstr "Obtener traducciones de la entrada"

msgid "Return the full translation map for a post: language, post ID, title, permalink, and status for each available translation."
msgstr "Devuelve el mapa completo de traducciones de una entrada: idioma, ID de entrada, título, permalink y estado para cada traducción disponible."

msgid "WooCommerce"
msgstr "WooCommerce"

msgid "Query and manage WooCommerce products, orders, and customers using the native WooCommerce API (HPOS-compatible)."
msgstr "Consulta y gestiona productos, pedidos y clientes de WooCommerce usando la API nativa de WooCommerce (compatible con HPOS)."

msgid "Get Products"
msgstr "Obtener productos"

msgid "List products with price, SKU, stock status, categories, and type. Supports search and category filter."
msgstr "Lista productos con precio, SKU, estado del stock, categorías y tipo. Admite búsqueda y filtro por categoría."

msgid "Get Single Product"
msgstr "Obtener un producto"

msgid "Full product detail: price, SKU, stock, description, gallery, attributes, and variations for variable products."
msgstr "Detalle completo del producto: precio, SKU, stock, descripción, galería, atributos y variaciones para productos variables."

msgid "Update Product"
msgstr "Actualizar producto"

msgid "Update product price, sale price, stock quantity, status, or description using the WooCommerce API."
msgstr "Actualiza el precio, precio de oferta, cantidad en stock, estado o descripción del producto usando la API de WooCommerce."

msgid "Get Orders"
msgstr "Obtener pedidos"

msgid "List orders with customer, total, status, and date. HPOS-compatible. Supports filter by status."
msgstr "Lista pedidos con cliente, total, estado y fecha. Compatible con HPOS. Admite filtro por estado."

msgid "Get Single Order"
msgstr "Obtener un pedido"

msgid "Full order detail: line items, customer billing/shipping, totals, status history, and notes."
msgstr "Detalle completo del pedido: líneas de pedido, facturación/envío del cliente, totales, historial de estados y notas."

msgid "Update Order Status"
msgstr "Actualizar estado del pedido"

msgid "Change the status of an order (e.g., pending → processing → completed) with an optional note."
msgstr "Cambia el estado de un pedido (p. ej., pendiente → procesando → completado) con una nota opcional."

msgid "Get Customers"
msgstr "Obtener clientes"

msgid "List customers with email, name, total spent, and order count. Supports search by email or name."
msgstr "Lista clientes con correo electrónico, nombre, total gastado y número de pedidos. Admite búsqueda por correo o nombre."

msgid "The Events Calendar"
msgstr "The Events Calendar"

msgid "Query and manage events from The Events Calendar plugin, including dates, venues, and organizers."
msgstr "Consulta y gestiona eventos del plugin The Events Calendar, incluyendo fechas, lugares y organizadores."

msgid "Get Events"
msgstr "Obtener eventos"

msgid "List events with start/end date, venue, and organizer. Supports upcoming/past filter and date range."
msgstr "Lista eventos con fecha de inicio/fin, lugar y organizador. Admite filtro de próximos/pasados y rango de fechas."

msgid "Get Single Event"
msgstr "Obtener un evento"

msgid "Full event detail with resolved venue address and organizer contact info in a single call."
msgstr "Detalle completo del evento con la dirección del lugar y la información de contacto del organizador en una sola llamada."

msgid "Create Event"
msgstr "Crear evento"

msgid "Create a new event with title, description, start/end dates, timezone, and venue (by ID or name)."
msgstr "Crea un nuevo evento con título, descripción, fechas de inicio/fin, zona horaria y lugar (por ID o nombre)."

msgid "Update Event"
msgstr "Actualizar evento"

msgid "Update an existing event: title, description, start/end dates, timezone, or venue."
msgstr "Actualiza un evento existente: título, descripción, fechas de inicio/fin, zona horaria o lugar."

msgid "Custom Post Types"
msgstr "Tipos de contenido personalizados"

msgid "Discover and manage Custom Post Types registered by plugins or themes. Excludes posts, pages, and attachments which have dedicated abilities."
msgstr "Descubre y gestiona los tipos de contenido personalizados registrados por plugins o temas. Excluye entradas, páginas y adjuntos, que tienen capacidades dedicadas."

msgid "List Post Types"
msgstr "Listar tipos de contenido"

msgid "List all public Custom Post Types with their labels, taxonomies, supported features, and capabilities."
msgstr "Lista todos los tipos de contenido personalizados públicos con sus etiquetas, taxonomías, características admitidas y capacidades."

msgid "Get CPT Items"
msgstr "Obtener elementos de CPT"

msgid "List items from any CPT with filters by status, count, order, and search."
msgstr "Lista elementos de cualquier tipo de contenido personalizado con filtros por estado, cantidad, orden y búsqueda."

msgid "Get Single CPT Item"
msgstr "Obtener un elemento de CPT"

msgid "Get full detail of a CPT item by ID, including content, meta data, taxonomies, and featured image."
msgstr "Obtiene el detalle completo de un elemento de CPT por ID, incluyendo contenido, metadatos, taxonomías e imagen destacada."

msgid "Create CPT Item"
msgstr "Crear elemento de CPT"

msgid "Create a new item in any CPT with title, content, status, taxonomies, and featured image."
msgstr "Crea un nuevo elemento en cualquier tipo de contenido personalizado con título, contenido, estado, taxonomías e imagen destacada."

msgid "Update CPT Item"
msgstr "Actualizar elemento de CPT"

msgid "Update an existing CPT item. Only modifies the fields provided."
msgstr "Actualiza un elemento de CPT existente. Solo modifica los campos proporcionados."

msgid "Delete CPT Item"
msgstr "Eliminar elemento de CPT"

msgid "Send a CPT item to trash or permanently delete it."
msgstr "Envía un elemento de CPT a la papelera o lo elimina de forma permanente."

msgid "Get CPT Taxonomies"
msgstr "Obtener taxonomías de CPT"

msgid "List taxonomies and their terms for a given CPT."
msgstr "Lista las taxonomías y sus términos para un tipo de contenido personalizado concreto."

msgid "Assign Terms to CPT Item"
msgstr "Asignar términos a elemento de CPT"

msgid "Assign taxonomy terms to a CPT item. Can add to or replace existing terms."
msgstr "Asigna términos de taxonomía a un elemento de CPT. Puede añadir a los términos existentes o reemplazarlos."

msgid "No Custom Post Types detected on this site. These abilities will become available when a plugin or theme registers custom post types (e.g., WooCommerce, ACF, JetEngine)."
msgstr "No se han detectado tipos de contenido personalizados en este sitio. Estas capacidades estarán disponibles cuando un plugin o tema registre tipos de contenido personalizados (p. ej., WooCommerce, ACF, JetEngine)."

msgid "Rank Math SEO plugin is not active. These abilities require Rank Math to function."
msgstr "El plugin Rank Math SEO no está activo. Estas capacidades requieren Rank Math para funcionar."

msgid "SEOPress plugin is not active. These abilities require SEOPress to function."
msgstr "El plugin SEOPress no está activo. Estas capacidades requieren SEOPress para funcionar."

msgid "Yoast SEO plugin is not active. These abilities require Yoast SEO to function."
msgstr "El plugin Yoast SEO no está activo. Estas capacidades requieren Yoast SEO para funcionar."

msgid "WooCommerce is not active. These abilities require WooCommerce to function."
msgstr "WooCommerce no está activo. Estas capacidades requieren WooCommerce para funcionar."

msgid "The Events Calendar plugin is not active. These abilities require The Events Calendar to function."
msgstr "El plugin The Events Calendar no está activo. Estas capacidades requieren The Events Calendar para funcionar."

msgid "Code Snippets plugin is not active. This ability requires Code Snippets 2.x or 3.x to function."
msgstr "El plugin Code Snippets no está activo. Esta capacidad requiere Code Snippets 2.x o 3.x para funcionar."

msgid "Security: snippets are always saved as inactive and must be activated manually from wp-admin › Snippets. Enable only in trusted environments. Requires manage_options."
msgstr "Seguridad: los fragmentos siempre se guardan como inactivos y deben activarse manualmente desde wp-admin › Fragmentos. Habilitar solo en entornos de confianza. Requiere manage_options."

msgid "No multilanguage plugin detected. These abilities require Polylang or WPML to function."
msgstr "No se ha detectado ningún plugin multiidioma. Estas capacidades requieren Polylang o WPML para funcionar."

msgid "This content type has dedicated abilities. Use the specific abilities for posts, pages, or media instead."
msgstr "Este tipo de contenido tiene capacidades dedicadas. Usa las capacidades específicas para entradas, páginas o medios."

msgid "The specified content type does not exist."
msgstr "El tipo de contenido especificado no existe."

msgid "This content type is not publicly accessible."
msgstr "Este tipo de contenido no es de acceso público."

msgid "Content Management"
msgstr "Gestión de contenido"

msgid "Abilities to create, read, update, and delete blog content."
msgstr "Capacidades para crear, leer, actualizar y eliminar contenido del blog."

msgid "User Management"
msgstr "Gestión de usuarios"

msgid "Abilities to query site user information."
msgstr "Capacidades para consultar la información de los usuarios del sitio."

msgid "Abilities to get general information and site statistics."
msgstr "Capacidades para obtener información general y estadísticas del sitio."

msgid "Abilities to discover and manage custom post types registered by plugins or themes."
msgstr "Capacidades para descubrir y gestionar los tipos de contenido personalizados registrados por plugins o temas."

msgid "Abilities to manage WooCommerce products, orders, and customers."
msgstr "Capacidades para gestionar productos, pedidos y clientes de WooCommerce."

msgid "Abilities to list, get, create, and update events from The Events Calendar."
msgstr "Capacidades para listar, obtener, crear y actualizar eventos de The Events Calendar."

msgid "Abilities to manage post languages and translation groups via Polylang or WPML."
msgstr "Capacidades para gestionar los idiomas de las entradas y los grupos de traducción mediante Polylang o WPML."

msgid "Retrieves a list of blog posts with optional filters by status, category, count, and order."
msgstr "Recupera una lista de entradas del blog con filtros opcionales por estado, categoría, cantidad y orden."

msgid "Retrieves all details of a specific post by ID, including full content, metadata, and featured image."
msgstr "Recupera todos los detalles de una entrada específica por ID, incluyendo el contenido completo, los metadatos y la imagen destacada."

msgid "Retrieves all details of a specific page by ID, including full content, template, hierarchy, and SEO metadata."
msgstr "Recupera todos los detalles de una página específica por ID, incluyendo el contenido completo, la plantilla, la jerarquía y los metadatos SEO."

msgid "Retrieves all blog categories with their ID, name, slug, description, and post count."
msgstr "Recupera todas las categorías del blog con su ID, nombre, slug, descripción y recuento de entradas."

msgid "Retrieves all blog tags with their ID, name, slug, and post count."
msgstr "Recupera todas las etiquetas del blog con su ID, nombre, slug y recuento de entradas."

msgid "Retrieves site pages with their title, status, content, and hierarchy (parent/child)."
msgstr "Recupera las páginas del sitio con su título, estado, contenido y jerarquía (padre/hijo)."

msgid "Retrieves blog comments with optional filters by status, post, and count. Useful for moderation and analysis."
msgstr "Recupera los comentarios del blog con filtros opcionales por estado, entrada y cantidad. Útil para moderación y análisis."

msgid "Retrieves media library files (images, videos, documents) with filters by MIME type and search."
msgstr "Recupera los archivos de la biblioteca de medios (imágenes, vídeos, documentos) con filtros por tipo MIME y búsqueda."

msgid "Retrieves the list of site users with their ID, name, email, and role. Useful for assigning post authors."
msgstr "Recupera la lista de usuarios del sitio con su ID, nombre, correo electrónico y rol. Útil para asignar autores a entradas."

msgid "Creates a new blog post. Accepts title, HTML content, excerpt, categories, tags, featured image, and status. Defaults to draft."
msgstr "Crea una nueva entrada en el blog. Acepta título, contenido HTML, extracto, categorías, etiquetas, imagen destacada y estado. Por defecto, se crea como borrador."

msgid "Updates an existing post. Only the provided fields are modified, others remain unchanged."
msgstr "Actualiza una entrada existente. Solo se modifican los campos proporcionados; los demás permanecen sin cambios."

msgid "Sends a post to trash or permanently deletes it. Defaults to trash."
msgstr "Envía una entrada a la papelera o la elimina de forma permanente. Por defecto, va a la papelera."

msgid "Creates a new blog category with name, slug, description, and parent category (optional)."
msgstr "Crea una nueva categoría de blog con nombre, slug, descripción y categoría padre (opcional)."

msgid "Creates a new blog tag with name, slug, and description."
msgstr "Crea una nueva etiqueta de blog con nombre, slug y descripción."

msgid "Creates a new WordPress page with title, content, status, and parent page (for hierarchy)."
msgstr "Crea una nueva página de WordPress con título, contenido, estado y página padre (para jerarquía)."

msgid "Changes a comment status: approve, hold, mark as spam, or send to trash."
msgstr "Cambia el estado de un comentario: aprobar, retener, marcar como spam o enviar a la papelera."

msgid "Replies to an existing comment on a post or page. The reply is published as the current authenticated user."
msgstr "Responde a un comentario existente en una entrada o página. La respuesta se publica como el usuario autenticado actual."

msgid "Updates an existing comment. Allows changing the content, author name, author email, and the WordPress user associated with the comment."
msgstr "Actualiza un comentario existente. Permite cambiar el contenido, el nombre del autor, el correo electrónico del autor y el usuario de WordPress asociado al comentario."

msgid "Downloads an image from an external URL and registers it in the WordPress media library. Optionally assigns it as featured image for a post. Returns the attachment ID and local URL."
msgstr "Descarga una imagen de una URL externa y la registra en la biblioteca de medios de WordPress. Opcionalmente, la asigna como imagen destacada de una entrada. Devuelve el ID del adjunto y la URL local."

msgid "Retrieves all Rank Math SEO metadata for a post or page: title, description, keywords, robots, advanced robots, Open Graph, Twitter Card, schema, breadcrumb, cornerstone, and SEO score."
msgstr "Recupera todos los metadatos SEO de Rank Math para una entrada o página: título, descripción, palabras clave, robots, robots avanzados, Open Graph, Twitter Card, esquema, miga de pan, piedra angular y puntuación SEO."

msgid "Updates Rank Math SEO metadata on a post or page (rank_math_focus_keyword, rank_math_title, rank_math_description, etc). Use this ability to set or change the focus keyword, SEO title, meta description, canonical URL, robots, Open Graph, Twitter Card, breadcrumb, schema snippet, cornerstone, and pillar content. Only the provided fields are modified."
msgstr "Actualiza los metadatos SEO de Rank Math en una entrada o página (rank_math_focus_keyword, rank_math_title, rank_math_description, etc.). Usa esta capacidad para establecer o cambiar la palabra clave principal, el título SEO, la metadescripción, la URL canónica, los robots, Open Graph, Twitter Card, la miga de pan, el fragmento de esquema, la piedra angular y el contenido pilar. Solo se modifican los campos proporcionados."

msgid "Writes a structured-data schema block (e.g. FAQPage, Article, Product) to a Rank Math schema meta key. The schema_data object is sanitized and stored as a PHP-serialized array, exactly as Rank Math expects, so it renders as JSON-LD in <head>. Use this to add or replace a schema block on any post or page."
msgstr "Escribe un bloque de esquema de datos estructurados (p. ej., FAQPage, Article, Product) en la clave meta de esquema de Rank Math. El objeto schema_data se sanea y almacena como un array serializado en PHP, tal y como Rank Math lo espera, de modo que se muestre como JSON-LD en el <head>. Úsalo para añadir o reemplazar un bloque de esquema en cualquier entrada o página."

msgid "ID of the post or page to update."
msgstr "ID de la entrada o página a actualizar."

msgid "Schema type suffix used as the Rank Math meta key name (rank_math_schema_{type}). Examples: FAQPage, Article, Product, VideoObject."
msgstr "Sufijo del tipo de esquema utilizado como nombre de la clave meta de Rank Math (rank_math_schema_{tipo}). Ejemplos: FAQPage, Article, Product, VideoObject."

msgid "The schema object to store. Must be a valid JSON object matching the chosen schema_type. String values are sanitized; URL fields (url, image, @context, sameAs, etc.) are run through esc_url_raw()."
msgstr "El objeto de esquema a almacenar. Debe ser un objeto JSON válido que coincida con el schema_type elegido. Los valores de cadena se sanean; los campos de URL (url, image, @context, sameAs, etc.) se procesan con esc_url_raw()."

msgid "Retrieves all SEOPress metadata for a post or page: title, description, focus keyword, robots directives, canonical URL, Open Graph, and Twitter Card."
msgstr "Recupera todos los metadatos de SEOPress para una entrada o página: título, descripción, palabra clave principal, directivas de robots, URL canónica, Open Graph y Twitter Card."

msgid "Updates SEOPress metadata on a post or page (_seopress_titles_title, _seopress_titles_desc, etc). Use this to set or change the SEO title, meta description, focus keyword, canonical URL, robots directives, and Open Graph / Twitter Card fields. Only the provided fields are modified."
msgstr "Actualiza los metadatos de SEOPress en una entrada o página (_seopress_titles_title, _seopress_titles_desc, etc.). Úsalo para establecer o cambiar el título SEO, la metadescripción, la palabra clave principal, la URL canónica, las directivas de robots y los campos de Open Graph/Twitter Card. Solo se modifican los campos proporcionados."

msgid "Retrieves all Yoast SEO metadata for a post or page: title, description, focus keyphrase, canonical URL, robots (noindex/nofollow/advanced), Open Graph, and Twitter Card."
msgstr "Recupera todos los metadatos de Yoast SEO para una entrada o página: título, descripción, frase clave principal, URL canónica, robots (noindex/nofollow/avanzado), Open Graph y Twitter Card."

msgid "Updates Yoast SEO metadata on a post or page (_yoast_wpseo_title, _yoast_wpseo_metadesc, etc). Use this to set or change the SEO title, meta description, focus keyphrase, canonical URL, robots, and Open Graph / Twitter Card fields. Only the provided fields are modified."
msgstr "Actualiza los metadatos de Yoast SEO en una entrada o página (_yoast_wpseo_title, _yoast_wpseo_metadesc, etc.). Úsalo para establecer o cambiar el título SEO, la metadescripción, la frase clave principal, la URL canónica, los robots y los campos de Open Graph/Twitter Card. Solo se modifican los campos proporcionados."

msgid "Creates a PHP code snippet via the Code Snippets plugin. The snippet is always saved as inactive — it must be activated manually from wp-admin › Snippets. Validates PHP syntax, blocks dangerous functions, and fires an audit action hook after saving."
msgstr "Crea un fragmento de código PHP a través del plugin Code Snippets. El fragmento siempre se guarda como inactivo; debe activarse manualmente desde wp-admin › Fragmentos. Valida la sintaxis PHP, bloquea funciones peligrosas y activa un hook de auditoría tras guardar."

#. translators: %s: function name
#, php-format
msgid "The function '%s' is not allowed in code snippets for security reasons."
msgstr "La función «%s» no está permitida en los fragmentos de código por razones de seguridad."

#. translators: 1: snippet title, 2: snippet ID, 3: edit URL
#, php-format
msgid "Snippet '%1$s' (ID %2$d) created as INACTIVE. Activate manually from: %3$s"
msgstr "Fragmento «%1$s» (ID %2$d) creado como INACTIVO. Actívalo manualmente desde: %3$s"

msgid "Fetches and parses the Yoast SEO sitemap index for this site, returning the list of all sitemap URLs and their last modification date."
msgstr "Obtiene y analiza el índice del mapa del sitio de Yoast SEO, devolviendo la lista de todas las URLs de los mapas del sitio y su fecha de última modificación."

msgid "Searches for text in a specific post content and replaces it with another. Useful for corrections and updates."
msgstr "Busca texto en el contenido de una entrada específica y lo reemplaza por otro. Útil para correcciones y actualizaciones."

msgid "Returns a summary with the total posts, pages, categories, tags, comments, and users of the site."
msgstr "Devuelve un resumen con el total de entradas, páginas, categorías, etiquetas, comentarios y usuarios del sitio."

msgid "Writes any post meta field by exact key. Use this when you know the exact meta key required by a specific SEO plugin or custom field (e.g. _genesis_title for The SEO Framework, _seopress_titles_title for SEOPress). Requires edit_post capability on the target post."
msgstr "Escribe cualquier campo de metadato de una entrada por clave exacta. Úsalo cuando conozcas la clave meta exacta requerida por un plugin SEO específico o un campo personalizado (p. ej., _genesis_title para The SEO Framework, _seopress_titles_title para SEOPress). Requiere la capacidad edit_post en la entrada de destino."

msgid "Reads any single post meta field by exact key. Useful for SEO plugins and custom fields not covered by dedicated sections (e.g. _genesis_title for The SEO Framework, _aioseo_title for AIOSEO). Requires edit_post capability on the target post."
msgstr "Lee cualquier campo de metadato de una entrada por clave exacta. Útil para plugins SEO y campos personalizados no cubiertos por secciones dedicadas (p. ej., _genesis_title para The SEO Framework, _aioseo_title para AIOSEO). Requiere la capacidad edit_post en la entrada de destino."

msgid "ID of the post or page to read."
msgstr "ID de la entrada o página a leer."

msgid "Exact meta key to read (e.g. _genesis_title, _aioseo_title, _custom_field)."
msgstr "Clave meta exacta a leer (p. ej., _genesis_title, _aioseo_title, _custom_field)."

msgid "Returns a list of all currently active plugins on the site, including name, version, and detected capabilities (multilanguage, SEO, WooCommerce, etc.)."
msgstr "Devuelve una lista de todos los plugins actualmente activos en el sitio, incluyendo nombre, versión y capacidades detectadas (multiidioma, SEO, WooCommerce, etc.)."

msgid "Lists all custom post types registered on the site, with their configuration, supported features, and associated taxonomies."
msgstr "Lista todos los tipos de contenido personalizados registrados en el sitio, con su configuración, características admitidas y taxonomías asociadas."

msgid "No custom post types detected on this site."
msgstr "No se han detectado tipos de contenido personalizados en este sitio."

msgid "Retrieves a list of items from a specific custom post type with filtering, search, and taxonomy query support."
msgstr "Recupera una lista de elementos de un tipo de contenido personalizado específico con soporte para filtrado, búsqueda y consultas de taxonomía."

msgid "The custom post type slug (e.g. product, portfolio)."
msgstr "El slug del tipo de contenido personalizado (p. ej., product, portfolio)."

msgid "Number of items to return (default 20, max 100)."
msgstr "Número de elementos a devolver (por defecto 20, máximo 100)."

msgid "Filter by status: publish, draft, pending, private, any (default publish)."
msgstr "Filtrar por estado: publish, draft, pending, private, any (por defecto publish)."

msgid "Order by: date, title, modified, menu_order, ID, rand (default date)."
msgstr "Ordenar por: date, title, modified, menu_order, ID, rand (por defecto date)."

msgid "Sort direction: ASC or DESC (default DESC)."
msgstr "Dirección de ordenación: ASC o DESC (por defecto DESC)."

msgid "Search keyword to filter items."
msgstr "Palabra clave de búsqueda para filtrar elementos."

msgid "Taxonomy query array. Each item: {taxonomy, terms, field (slug|id), operator (IN|NOT IN|AND)}."
msgstr "Array de consulta de taxonomía. Cada elemento: {taxonomy, terms, field (slug|id), operator (IN|NOT IN|AND)}."

msgid "Get CPT Item"
msgstr "Obtener elemento de CPT"

msgid "Retrieves full details of a single custom post type item, including all meta fields, taxonomies, and content."
msgstr "Recupera los detalles completos de un elemento de tipo de contenido personalizado, incluyendo todos los campos meta, taxonomías y contenido."

msgid "The ID of the item to retrieve."
msgstr "El ID del elemento a recuperar."

msgid "Item not found."
msgstr "Elemento no encontrado."

msgid "Creates a new item in a custom post type. Content is optional as some CPTs store data in custom fields instead."
msgstr "Crea un nuevo elemento en un tipo de contenido personalizado. El contenido es opcional, ya que algunos CPT almacenan datos en campos personalizados."

msgid "The custom post type slug."
msgstr "El slug del tipo de contenido personalizado."

msgid "The item title."
msgstr "El título del elemento."

msgid "The item content (optional — some CPTs store data in meta fields instead)."
msgstr "El contenido del elemento (opcional: algunos CPT almacenan datos en campos meta)."

msgid "The item excerpt."
msgstr "El extracto del elemento."

msgid "Post status: draft, publish, pending, private (default draft)."
msgstr "Estado de la entrada: draft, publish, pending, private (por defecto draft)."

msgid "Attachment ID for the featured image."
msgstr "ID del adjunto para la imagen destacada."

msgid "Parent item ID (for hierarchical CPTs)."
msgstr "ID del elemento padre (para CPT jerárquicos)."

msgid "Menu order value."
msgstr "Valor del orden del menú."

msgid "Author user ID."
msgstr "ID del usuario autor."

msgid "The URL slug for the item."
msgstr "El slug de la URL para el elemento."

msgid "Object mapping taxonomy slugs to arrays of term slugs or IDs. Example: {\"product_cat\": [\"clothing\"], \"product_tag\": [\"sale\"]}."
msgstr "Objeto que mapea slugs de taxonomía a arrays de slugs o IDs de términos. Ejemplo: {\"product_cat\": [\"clothing\"], \"product_tag\": [\"sale\"]}."

msgid "Object mapping meta keys to values. Supports plugin meta like _price, _sku, ACF fields, etc."
msgstr "Objeto que mapea claves meta a valores. Admite meta de plugins como _price, _sku, campos de ACF, etc."

msgid "You do not have permission to create items of this type."
msgstr "No tienes permiso para crear elementos de este tipo."

#. translators: %s: post type label
#, php-format
msgid "%s created successfully."
msgstr "%s creado correctamente."

msgid "Updates an existing custom post type item. Only provided fields are modified (partial update)."
msgstr "Actualiza un elemento de tipo de contenido personalizado existente. Solo se modifican los campos proporcionados (actualización parcial)."

msgid "The ID of the item to update."
msgstr "El ID del elemento a actualizar."

msgid "New title."
msgstr "Nuevo título."

msgid "New content (optional — some CPTs use meta fields instead)."
msgstr "Nuevo contenido (opcional: algunos CPT usan campos meta)."

msgid "New excerpt."
msgstr "Nuevo extracto."

msgid "New status: draft, publish, pending, private."
msgstr "Nuevo estado: draft, publish, pending, private."

msgid "Attachment ID for the featured image. Pass 0 to remove."
msgstr "ID del adjunto para la imagen destacada. Pasa 0 para eliminarla."

msgid "New URL slug."
msgstr "Nuevo slug de URL."

msgid "Object mapping taxonomy slugs to arrays of term slugs or IDs. Replaces existing terms."
msgstr "Objeto que mapea slugs de taxonomía a arrays de slugs o IDs de términos. Reemplaza los términos existentes."

msgid "You do not have permission to edit this item."
msgstr "No tienes permiso para editar este elemento."

#. translators: %s: post type label
#, php-format
msgid "%s updated successfully."
msgstr "%s actualizado correctamente."

msgid "Deletes a custom post type item. By default moves to trash; use force_delete to permanently remove."
msgstr "Elimina un elemento de tipo de contenido personalizado. Por defecto lo mueve a la papelera; usa force_delete para eliminarlo permanentemente."

msgid "The ID of the item to delete."
msgstr "El ID del elemento a eliminar."

msgid "If true, permanently deletes instead of trashing (default false)."
msgstr "Si es verdadero, elimina permanentemente en lugar de mover a la papelera (por defecto false)."

msgid "You do not have permission to delete this item."
msgstr "No tienes permiso para eliminar este elemento."

msgid "Failed to delete the item."
msgstr "No se ha podido eliminar el elemento."

#. translators: %s: post type label
#, php-format
msgid "%s permanently deleted."
msgstr "%s eliminado permanentemente."

#. translators: %s: post type label
#, php-format
msgid "%s moved to trash."
msgstr "%s movido a la papelera."

msgid "Retrieves all taxonomies associated with a custom post type, including their terms."
msgstr "Recupera todas las taxonomías asociadas a un tipo de contenido personalizado, incluyendo sus términos."

msgid "If true, only show terms with posts (default false)."
msgstr "Si es verdadero, muestra solo los términos con entradas (por defecto false)."

msgid "Max number of terms per taxonomy (default 100, max 500)."
msgstr "Número máximo de términos por taxonomía (por defecto 100, máximo 500)."

msgid "Assign CPT Terms"
msgstr "Asignar términos de CPT"

msgid "Assigns taxonomy terms to a custom post type item. Can replace or append terms."
msgstr "Asigna términos de taxonomía a un elemento de tipo de contenido personalizado. Puede reemplazar o añadir términos."

msgid "The ID of the item to assign terms to."
msgstr "El ID del elemento al que asignar términos."

msgid "The taxonomy slug."
msgstr "El slug de la taxonomía."

msgid "Array of term slugs or IDs to assign."
msgstr "Array de slugs o IDs de términos a asignar."

msgid "If true, appends terms instead of replacing (default false)."
msgstr "Si es verdadero, añade términos en lugar de reemplazarlos (por defecto false)."

msgid "The specified taxonomy does not exist."
msgstr "La taxonomía especificada no existe."

#. translators: %1$s: taxonomy slug, %2$s: post type label
#, php-format
msgid "The taxonomy \"%1$s\" is not associated with the \"%2$s\" post type."
msgstr "La taxonomía «%1$s» no está asociada al tipo de contenido «%2$s»."

msgid "You do not have permission to assign terms for this taxonomy."
msgstr "No tienes permiso para asignar términos de esta taxonomía."

#. translators: %1$d: number of terms, %2$s: taxonomy label
#, php-format
msgid "%1$d term(s) assigned for %2$s."
msgstr "%1$d término(s) asignado(s) para %2$s."

msgid "List WooCommerce products"
msgstr "Listar productos de WooCommerce"

msgid "Returns a paginated list of WooCommerce products with price, stock, and status."
msgstr "Devuelve una lista paginada de productos de WooCommerce con precio, stock y estado."

msgid "Product status: publish, draft, pending. Default: publish."
msgstr "Estado del producto: publish, draft, pending. Por defecto: publish."

msgid "Results per page (1–100). Default: 10."
msgstr "Resultados por página (1–100). Por defecto: 10."

msgid "Page number. Default: 1."
msgstr "Número de página. Por defecto: 1."

msgid "Keyword search in product name."
msgstr "Búsqueda por palabra clave en el nombre del producto."

msgid "Filter by product category slug."
msgstr "Filtrar por slug de categoría de producto."

msgid "Order by: date, price, popularity, rating. Default: date."
msgstr "Ordenar por: date, price, popularity, rating. Por defecto: date."

msgid "Sort order: ASC or DESC. Default: DESC."
msgstr "Orden de clasificación: ASC o DESC. Por defecto: DESC."

msgid "Get WooCommerce product"
msgstr "Obtener producto de WooCommerce"

msgid "Returns full details of a single WooCommerce product by ID."
msgstr "Devuelve los detalles completos de un producto de WooCommerce por ID."

msgid "The product post ID."
msgstr "El ID de la entrada del producto."

msgid "Product not found."
msgstr "Producto no encontrado."

msgid "Update WooCommerce product"
msgstr "Actualizar producto de WooCommerce"

msgid "Updates price, stock, status, or description of a WooCommerce product using WooCommerce hooks."
msgstr "Actualiza el precio, stock, estado o descripción de un producto de WooCommerce usando los hooks de WooCommerce."

msgid "New regular price (numeric string)."
msgstr "Nuevo precio normal (cadena numérica)."

msgid "New sale price (numeric string, empty to clear)."
msgstr "Nuevo precio de oferta (cadena numérica, vacío para borrar)."

msgid "New stock quantity. Requires manage_stock to be enabled."
msgstr "Nueva cantidad de stock. Requiere que manage_stock esté activado."

msgid "Stock status: instock, outofstock, onbackorder."
msgstr "Estado del stock: instock, outofstock, onbackorder."

msgid "Product status: publish, draft, pending."
msgstr "Estado del producto: publish, draft, pending."

msgid "Full product description."
msgstr "Descripción completa del producto."

msgid "Product updated successfully."
msgstr "Producto actualizado correctamente."

msgid "List WooCommerce orders"
msgstr "Listar pedidos de WooCommerce"

msgid "Returns a paginated list of WooCommerce orders. HPOS-compatible."
msgstr "Devuelve una lista paginada de pedidos de WooCommerce. Compatible con HPOS."

msgid "Order status: pending, processing, on-hold, completed, cancelled, refunded, failed. Default: any."
msgstr "Estado del pedido: pending, processing, on-hold, completed, cancelled, refunded, failed. Por defecto: any."

msgid "Filter by customer user ID."
msgstr "Filtrar por ID de usuario cliente."

msgid "Filter orders created after this date (YYYY-MM-DD)."
msgstr "Filtrar pedidos creados después de esta fecha (AAAA-MM-DD)."

msgid "Filter orders created before this date (YYYY-MM-DD)."
msgstr "Filtrar pedidos creados antes de esta fecha (AAAA-MM-DD)."

msgid "Get WooCommerce order"
msgstr "Obtener pedido de WooCommerce"

msgid "Returns full details of a single WooCommerce order including line items and billing address. HPOS-compatible."
msgstr "Devuelve los detalles completos de un pedido de WooCommerce, incluyendo líneas de pedido y dirección de facturación. Compatible con HPOS."

msgid "The order ID."
msgstr "El ID del pedido."

msgid "Order not found."
msgstr "Pedido no encontrado."

msgid "Update WooCommerce order status"
msgstr "Actualizar estado de pedido de WooCommerce"

msgid "Changes the status of a WooCommerce order and optionally adds a note. HPOS-compatible."
msgstr "Cambia el estado de un pedido de WooCommerce y opcionalmente añade una nota. Compatible con HPOS."

msgid "New status: pending, processing, on-hold, completed, cancelled, refunded, failed."
msgstr "Nuevo estado: pending, processing, on-hold, completed, cancelled, refunded, failed."

msgid "Optional note to add to the order."
msgstr "Nota opcional a añadir al pedido."

msgid "Invalid order status."
msgstr "Estado de pedido no válido."

msgid "Order status updated."
msgstr "Estado del pedido actualizado."

msgid "List WooCommerce customers"
msgstr "Listar clientes de WooCommerce"

msgid "Returns a list of WooCommerce customers with order stats."
msgstr "Devuelve una lista de clientes de WooCommerce con estadísticas de pedidos."

msgid "Search by name or email."
msgstr "Buscar por nombre o correo electrónico."

msgid "Order by: registered, name, email. Default: registered."
msgstr "Ordenar por: registered, name, email. Por defecto: registered."

msgid "List Events Calendar events"
msgstr "Listar eventos de Events Calendar"

msgid "Returns a list of upcoming or filtered events from The Events Calendar."
msgstr "Devuelve una lista de eventos próximos o filtrados de The Events Calendar."

msgid "Return events starting after this date (YYYY-MM-DD). Default: today."
msgstr "Devuelve eventos que empiecen después de esta fecha (AAAA-MM-DD). Por defecto: hoy."

msgid "Return events starting before this date (YYYY-MM-DD)."
msgstr "Devuelve eventos que empiecen antes de esta fecha (AAAA-MM-DD)."

msgid "Keyword search in event title."
msgstr "Búsqueda por palabra clave en el título del evento."

msgid "Get Events Calendar event"
msgstr "Obtener evento de Events Calendar"

msgid "Returns full details of a single event including venue address and organizer."
msgstr "Devuelve los detalles completos de un evento, incluyendo la dirección del lugar y el organizador."

msgid "The event post ID."
msgstr "El ID de la entrada del evento."

msgid "Event not found."
msgstr "Evento no encontrado."

msgid "Create Events Calendar event"
msgstr "Crear evento de Events Calendar"

msgid "Creates a new event in The Events Calendar with title, dates, and optional venue."
msgstr "Crea un nuevo evento en The Events Calendar con título, fechas y lugar opcional."

msgid "Event title."
msgstr "Título del evento."

msgid "Event description (HTML allowed)."
msgstr "Descripción del evento (se permite HTML)."

msgid "Start date and time (YYYY-MM-DD HH:MM:SS)."
msgstr "Fecha y hora de inicio (AAAA-MM-DD HH:MM:SS)."

msgid "End date and time (YYYY-MM-DD HH:MM:SS)."
msgstr "Fecha y hora de fin (AAAA-MM-DD HH:MM:SS)."

msgid "Timezone string, e.g. America/New_York. Defaults to site timezone."
msgstr "Cadena de zona horaria, p. ej., America/New_York. Por defecto, usa la zona horaria del sitio."

msgid "Existing tribe_venue post ID to link."
msgstr "ID de entrada tribe_venue existente a vincular."

msgid "Existing tribe_organizer post ID to link."
msgstr "ID de entrada tribe_organizer existente a vincular."

msgid "Ticket/admission cost (free-form string)."
msgstr "Coste de la entrada/admisión (cadena de texto libre)."

msgid "External event URL."
msgstr "URL externa del evento."

msgid "Post status: publish, draft. Default: publish."
msgstr "Estado de la entrada: publish, draft. Por defecto: publish."

msgid "Event created successfully."
msgstr "Evento creado correctamente."

msgid "Update Events Calendar event"
msgstr "Actualizar evento de Events Calendar"

msgid "Updates an existing event's dates, title, description, venue, or status."
msgstr "Actualiza las fechas, el título, la descripción, el lugar o el estado de un evento existente."

msgid "New event title."
msgstr "Nuevo título del evento."

msgid "New event description."
msgstr "Nueva descripción del evento."

msgid "New start date and time (YYYY-MM-DD HH:MM:SS)."
msgstr "Nueva fecha y hora de inicio (AAAA-MM-DD HH:MM:SS)."

msgid "New end date and time (YYYY-MM-DD HH:MM:SS)."
msgstr "Nueva fecha y hora de fin (AAAA-MM-DD HH:MM:SS)."

msgid "Timezone string."
msgstr "Cadena de zona horaria."

msgid "Venue post ID to link."
msgstr "ID de entrada del lugar a vincular."

msgid "Organizer post ID to link."
msgstr "ID de entrada del organizador a vincular."

msgid "Admission cost."
msgstr "Coste de admisión."

msgid "Post status: publish, draft, private."
msgstr "Estado de la entrada: publish, draft, private."

msgid "Event updated successfully."
msgstr "Evento actualizado correctamente."

msgid "Assigns a language to an existing post via Polylang or WPML. Does nothing if no multilanguage plugin is active."
msgstr "Asigna un idioma a una entrada existente mediante Polylang o WPML. No hace nada si no hay ningún plugin multiidioma activo."

msgid "Links two posts as translations of each other via Polylang or WPML. Both posts must already have a language assigned."
msgstr "Vincula dos entradas como traducciones una de la otra mediante Polylang o WPML. Ambas entradas deben tener ya un idioma asignado."

msgid "Returns the full translation map for a post: language codes, post IDs, titles, and permalink for each available translation. Requires Polylang or WPML."
msgstr "Devuelve el mapa completo de traducciones de una entrada: códigos de idioma, IDs de entrada, títulos y permalink para cada traducción disponible. Requiere Polylang o WPML."

msgid "Insufficient permissions."
msgstr "Permisos insuficientes."

msgid "Logs cleared successfully."
msgstr "Registros borrados correctamente."

msgid "WP Abilities"
msgstr "WP Abilities"

#. translators: %1$s: opening <a> tag, %2$s: closing </a> tag
#, php-format
msgid "Enable Abilities for MCP requires the MCP Adapter plugin to work. %1$sDownload MCP Adapter%2$s"
msgstr "Enable Abilities for MCP requiere el plugin MCP Adapter para funcionar. %1$sDescargar MCP Adapter%2$s"

msgid "Ability keys updated to English for internationalization. Your settings have been preserved."
