msgid "ID of the post or page to update."
msgstr ""

#: includes/abilities.php:2556
msgid "Schema type suffix used as the Rank Math meta key name (rank_math_schema_{type}). Examples: FAQPage, Article, Product, VideoObject."
msgstr ""

#: includes/abilities.php:2567
msgid "The schema object to store. Must be a valid JSON object matching the chosen schema_type. String values are sanitized; URL fields (url, image, @context, sameAs, etc.) are run through esc_url_raw()."
msgstr ""

